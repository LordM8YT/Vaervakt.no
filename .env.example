DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=
DB_PORT=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:patrick@vaarvakt.no

YR_BATH_API_KEY=

VAERVAKT_DEBUG=0

# Valgfritt admin-dashboard på /admin.
# Hvis ADMIN_PASSWORD ikke settes, brukes DB_PASS som fallback på serveren.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=

# Valgfri ekstra hemmelighet for anonym besøks-hashing.
# Hvis den er tom, brukes ADMIN_PASSWORD_HASH, VAPID_PRIVATE_KEY eller DB_PASS som fallback.
VISIT_HASH_SECRET=

# Valgfri ekstra hemmelighet for hashing av API-nøkler til værstasjoner.
# Hvis den er tom, brukes VISIT_HASH_SECRET, ADMIN_PASSWORD_HASH, VAPID_PRIVATE_KEY eller DB_PASS som fallback.
STATION_KEY_PEPPER=

# Sett til 1 hvis offentlig selvbetjent forespørsel om ny værstasjon skal åpnes.
STATION_REQUESTS_ENABLED=0

# Valgfri støtteknapp.
SUPPORT_URL=https://betal.vipps.no/opy01u
SUPPORT_LABEL=Støtt med Vipps
