# Kopier til .env og fyll inn verdier. På noen webhotell kan ikke PHP lese .env;
# legg da samme variabler i serverens miljøpanel eller dupliser til en fil
# som webserveren leser (ikke eksponer den offentlig).

DB_HOST=localhost
# DB_PORT=3306
DB_NAME=database_navn
DB_USER=database_bruker
DB_PASS=bytt_meg

# VAPID_SUBJECT=mailto:deg@example.com
# VAPID_PUBLIC_KEY=din_offentlige_push_nokkel
# VAPID_PRIVATE_KEY=din_private_push_nokkel
# Alternativt kan du bruke de korte navnene:
# VAPID_PUBLIC=din_offentlige_push_nokkel
# VAPID_PRIVATE=din_private_push_nokkel
# VAERVAKT_DEBUG=1  # valgfritt: tillat ?vaervakt_debug=1 på index (kun ikke-sensitive felt)
# SUPPORT_URL=https://example.com/stott-med-vipps
# SUPPORT_LABEL=Støtt med Vipps
